OPENAI_API_KEY=sk-your-openai-api-key-here


# Whether to start the bundled MySQL container (compose profile: local-db).
#   true  = use the built-in MySQL container (quickest start, recommended)
#   false = use an EXTERNAL MySQL; you MUST also set MYSQL_HOST below
USE_LOCAL_DB=true

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=echoflow
MYSQL_PASSWORD=echoflow123
MYSQL_DATABASE=echoflow

# Only used when USE_LOCAL_DB=true (root password for the bundled MySQL)
MYSQL_ROOT_PASSWORD=root123456

# Host port that the bundled MySQL is exposed on (avoid clashing with a local
# MySQL already running on 3306). Only relevant when USE_LOCAL_DB=true.
LOCAL_MYSQL_EXPOSE_PORT=3307

# Connection pool tuning (optional, defaults shown)
MYSQL_CONNECTION_LIMIT=10
MYSQL_QUEUE_LIMIT=0
MYSQL_CHARSET=utf8mb4
MYSQL_TIMEZONE=Z


# -----------------------------------------------------------------------------
# 3. User authentication (optional, sane defaults provided)
# -----------------------------------------------------------------------------
AUTH_COOKIE_NAME=echoflow_user_session
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_SECURE=auto
AUTH_SESSION_SECRET=replace-with-a-random-long-string
AUTH_SESSION_TTL_HOURS=168
AUTH_RESET_TOKEN_TTL_MINUTES=30
AUTH_EXPOSE_RESET_TOKEN=true
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_FAILED_LOGIN_WINDOW_MINUTES=15
AUTH_LOCKOUT_MINUTES=15
AUTH_DEFAULT_ROLE=user
AUTH_PASSWORD_SALT_LENGTH=16
AUTH_PASSWORD_KEY_LENGTH=64


# -----------------------------------------------------------------------------
# Admin console (optional, leave empty to disable)
# -----------------------------------------------------------------------------
# When ADMIN_PASSWORD is empty the admin console endpoints are disabled.
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
ADMIN_SESSION_TTL_HOURS=12
ADMIN_COOKIE_NAME=echoflow_admin_session

COS_SECRET_ID=your-tencent-cloud-secret-id
COS_SECRET_KEY=your-tencent-cloud-secret-key
COS_BUCKET=your-bucket-name
COS_ENDPOINT=cos.ap-guangzhou.myqcloud.com
COS_REGION=ap-guangzhou

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=EchoFlow

VIDEO_URL_FEATURE_ENABLED=true
VIDEO_URL_MAX_DURATION_SECONDS=14400
VIDEO_URL_MAX_TASKS_PER_HOUR=5
VIDEO_URL_MAX_FILE_SIZE_MB=500
YT_DLP_TIMEOUT_MS=600000
YT_DLP_BINARY=yt-dlp
YT_DLP_COOKIES_FILE=

ACME_EMAIL=admin@example.com
