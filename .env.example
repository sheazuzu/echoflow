# MeetingMind 应用环境变量配置
# 复制此文件为 .env 并填入实际值

# OpenAI API Key (必需)
OPENAI_API_KEY=sk-your-openai-api-key-here

# 后端服务配置
BACKEND_PORT=3000
FRONTEND_PORT=80

# MySQL 配置（用户认证存储必需）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=your-mysql-user
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=echoflow
MYSQL_CONNECTION_LIMIT=10
MYSQL_QUEUE_LIMIT=0
MYSQL_CHARSET=utf8mb4
MYSQL_TIMEZONE=Z

# 用户认证配置（可选）
AUTH_COOKIE_NAME=echoflow_user_session
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_SECURE=auto
AUTH_SESSION_SECRET=replace-with-a-random-long-string
AUTH_SESSION_TTL_HOURS=168
AUTH_RESET_TOKEN_TTL_MINUTES=30
AUTH_EXPOSE_RESET_TOKEN=true
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_FAILED_LOGIN_WINDOW_MINUTES=15
AUTH_LOCKOUT_MINUTES=15
AUTH_DEFAULT_ROLE=user
AUTH_PASSWORD_SALT_LENGTH=16
AUTH_PASSWORD_KEY_LENGTH=64

# 腾讯云COS配置（可选，如不配置将使用本地文件存储）
COS_SECRET_ID=your-tencent-cloud-secret-id
COS_SECRET_KEY=your-tencent-cloud-secret-key
COS_BUCKET=your-bucket-name
COS_ENDPOINT=cos.ap-guangzhou.myqcloud.com
COS_REGION=ap-guangzhou

# SMTP邮件服务配置（用于发送会议纪要邮件）
# SMTP服务器地址（例如：Gmail使用smtp.gmail.com，QQ邮箱使用smtp.qq.com）
SMTP_HOST=smtp.gmail.com
# SMTP端口（587用于TLS，465用于SSL）
SMTP_PORT=587
# 是否使用SSL（true/false）
SMTP_SECURE=false
# 发件人邮箱地址
SMTP_USER=your-email@gmail.com
# 邮箱密码或授权码（Gmail需要使用应用专用密码）
SMTP_PASS=your-app-password
# 发件人显示名称
SMTP_FROM_NAME=EchoFlow

# Let's Encrypt 邮箱 (用于 HTTPS 证书通知)
ACME_EMAIL=admin@example.com

# 视频链接转录功能配置（YouTube / Bilibili）
# 是否启用视频链接转录功能（true/false），关闭时前端入口隐藏且后端路由返回 404
VIDEO_URL_FEATURE_ENABLED=true
# 视频最长时长限制（秒），默认 14400 秒（4 小时）
VIDEO_URL_MAX_DURATION_SECONDS=14400
# 单个用户每小时最多可提交的视频转录任务数
VIDEO_URL_MAX_TASKS_PER_HOUR=5
# 下载后音频文件大小上限（MB），超出将拒绝处理
VIDEO_URL_MAX_FILE_SIZE_MB=500
# yt-dlp 调用超时时间（毫秒），默认 600000（10 分钟）
YT_DLP_TIMEOUT_MS=600000
# yt-dlp 可执行文件名/路径（默认 yt-dlp，需在 PATH 中可执行）
YT_DLP_BINARY=yt-dlp
# Bilibili cookies 文件路径（可选，用于下载需要登录的清晰度/会员视频）
YT_DLP_COOKIES_FILE=

# 部署脚本（deploy.sh）控制项
# 是否在 docker-compose 中启动内置的 MySQL 容器（compose profile: local-db）
# true=启动容器内 MySQL（推荐快速本地部署）；false=使用外部 MySQL，需自行配置 DOCKER_MYSQL_HOST 等
USE_LOCAL_DB=true
# 当 USE_LOCAL_DB=true 时，DOCKER_MYSQL_HOST 应为 compose 服务名 "mysql"
# 当 USE_LOCAL_DB=false 时（外部 MySQL），常见取值：
#   - macOS/Windows Docker Desktop: host.docker.internal
#   - Linux 宿主机: 172.17.0.1 或宿主机内网 IP
DOCKER_MYSQL_HOST=mysql
DOCKER_MYSQL_PORT=3306
DOCKER_MYSQL_USER=echoflow
DOCKER_MYSQL_PASSWORD=echoflow123
DOCKER_MYSQL_DATABASE=echoflow
DOCKER_MYSQL_ROOT_PASSWORD=root123456
# 容器内 MySQL 在宿主机暴露的端口（避免与本机 3306 冲突）
LOCAL_MYSQL_EXPOSE_PORT=3307
